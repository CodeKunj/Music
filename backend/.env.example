# ─── Supabase ─────────────────────────────────────────────────
# Copy from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8090,http://127.0.0.1:8090,http://localhost:5173

# ─── Admin Auth ───────────────────────────────────────────────
# The admin's email (used to verify Supabase Auth JWT belongs to admin)
ADMIN_EMAIL=admin@example.com

# ─── Optional: Email notifications for contact form ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=kunj@example.com
